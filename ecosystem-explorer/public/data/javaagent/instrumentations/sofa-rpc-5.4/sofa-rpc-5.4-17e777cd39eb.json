{
  "configurations": [
    {
      "declarative_name": "java.common.service_peer_mapping",
      "declarative_schema": {
        "properties": {
          "peer": {
            "description": "Host name or IP address to match against.",
            "type": "string"
          },
          "service_name": {
            "description": "Peer service name to record for matching peers.",
            "type": "string"
          }
        },
        "required": [
          "peer",
          "service_name"
        ],
        "type": "object"
      },
      "declarative_type": "structured_list",
      "default": "",
      "description": "Used to specify a mapping from host names or IP addresses to peer services.",
      "name": "otel.instrumentation.common.peer-service-mapping",
      "type": "structured_list"
    }
  ],
  "description": "The SOFARPC instrumentation provides RPC client spans and metrics, and RPC server spans and metrics for SOFARPC RPC calls.",
  "display_name": "SOFARPC",
  "has_javaagent": true,
  "has_standalone_library": true,
  "javaagent_target_versions": [
