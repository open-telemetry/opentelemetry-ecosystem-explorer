{
  "component_type": "receiver",
  "description": "This receiver periodically retrieves the clock offset from a NTP server.",
  "display_name": "NTP Receiver",
  "distribution": "contrib",
  "metrics": {
    "ntp.offset": {
      "description": "Time difference between local and NTP server clocks",
      "enabled": true,
      "gauge": {
        "value_type": "int"
      },
      "stability": "development",
      "unit": "ns"
    }
  },
  "name": "ntpreceiver",
  "repository": "opentelemetry-collector-contrib",
  "resource_attributes": {
    "ntp.host": {
      "description": "NTP server used. Corresponds to configured `host`.",
      "type": "string"
    }
  },
  "status": {
    "class": "receiver",
    "codeowners": {
      "active": [
        "atoulme",
        "paulojmdias"
      ],
      "seeking_new": true
    },
    "distributions": [
      "contrib"
    ],
    "stability": {
      "beta": [
        "metrics"
      ]
    }
  },
  "type": "ntp",
  "version": "0.150.0"
}