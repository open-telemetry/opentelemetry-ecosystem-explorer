{
  "attributes": {
    "active.status": {
      "description": "The active status.",
      "enum": [
        "active",
        "inactive"
      ],
      "name_override": "status",
      "type": "string"
    },
    "availability.status": {
      "description": "The availability status.",
      "enum": [
        "available",
        "offline",
        "unknown"
      ],
      "name_override": "status",
      "type": "string"
    },
    "direction": {
      "description": "The direction of data.",
      "enum": [
        "received",
        "sent"
      ],
      "type": "string"
    },
    "enabled.status": {
      "description": "The enabled status.",
      "enum": [
        "disabled",
        "enabled"
      ],
      "name_override": "status",
      "type": "string"
    }
  },
  "component_type": "receiver",
  "distribution": "contrib",
  "metrics": {
    "bigip.node.availability": {
      "attributes": [
        "availability.status"
      ],
      "description": "Availability of the node.",
      "enabled": true,
      "gauge": {
        "value_type": "int"
      },
      "stability": {
        "level": "development"
      },
      "unit": "1"
    },
    "bigip.node.connection.count": {
      "description": "Current number of connections to the node.",
      "enabled": true,
      "stability": {
        "level": "development"
      },
      "sum": {
        "aggregation_temporality": "cumulative",
        "monotonic": false,
        "value_type": "int"
      },
      "unit": "{connections}"
    },
    "bigip.node.data.transmitted": {
      "attributes": [
        "direction"
      ],
      "description": "Amount of data transmitted to and from the node.",
      "enabled": true,
      "stability": {
        "level": "development"
      },
      "sum": {
        "aggregation_temporality": "cumulative",
        "monotonic": true,
        "value_type": "int"
      },
      "unit": "By"
    },
