      ],
      "seeking_new": true
    },
    "distributions": [
      "contrib"
    ],
    "stability": {
      "beta": [
        "metrics"
      ]
    },
    "unsupported_platforms": [
      "(windows && arm64)",
      "darwin",
      "linux"
    ]
  },
  "type": "receiver"
}